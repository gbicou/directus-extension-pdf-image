{
	"name": "@bicou/directus-extension-pdf-image",
	"description": "Directus extension to create a screenshot image for each uploaded PDF document",
	"icon": "extension",
	"homepage": "https://github.com/gbicou/directus-extension-pdf-image",
	"author": "Benjamin VIELLARD <bicou@bicou.com>",
	"license": "MIT",
	"repository": "github:gbicou/directus-extension-pdf-image",
	"version": "0.0.8",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-hook",
		"pdf",
		"image"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "hook",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate",
		"test": "vitest run",
		"lint": "eslint"
	},
	"dependencies": {
		"pdf-to-img": "^5.0.0"
	},
	"devDependencies": {
		"@directus/api": "33.3.1",
		"@directus/extensions-sdk": "17.0.9",
		"@directus/sdk": "21.1.0",
		"@eslint/js": "10.0.1",
		"@stylistic/eslint-plugin": "5.9.0",
		"@types/node": "22.19.15",
		"dotenv": "17.3.1",
		"eslint": "10.0.3",
		"rollup-plugin-node-externals": "8.1.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.56.0",
		"vitest": "4.0.18"
	},
	"peerDependencies": {
		"@directus/api": "^29.1.1 || ^32.0.0 || ^33.0.0",
		"@directus/extensions-sdk": "^16.0.0 || ^17.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"pnpm": {
		"onlyBuiltDependencies": [
			"argon2",
			"canvas",
			"esbuild",
			"isolated-vm",
			"sharp"
		],
		"ignoredBuiltDependencies": [
			"oracledb",
			"sqlite3"
		]
	}
}
